{
  "appId": "com.logstudio.app",
  "productName": "LogStudio",
  "copyright": "Copyright © 2025 LogStudio",
  "directories": {
    "output": "release"
  },
  "publish": {
    "provider": "github",
    "owner": "DrScince",
    "repo": "LogStudio"
  },
  "files": [
    "dist/**/*",
    "package.json",
    "public/LogStudio_Logo.ico",
    "LogStudio_Logo.png",
    "CHANGELOG.md"
  ],
  "fileAssociations": [
    {
      "ext": "log",
      "name": "Log File",
      "description": "Log File",
      "icon": "public/LogStudio_Logo.ico",
      "role": "Editor"
    },
    {
      "ext": "txt",
      "name": "Text File",
      "description": "Text File",
      "icon": "public/LogStudio_Logo.ico",
      "role": "Editor"
    }
  ],
  "win": {
    "target": [
      {
        "target": "nsis",
        "arch": ["x64"]
      },
      {
        "target": "portable",
        "arch": ["x64"]
      }
    ],
    "icon": "public/LogStudio_Logo.ico",
    "artifactName": "${productName}-${version}-${arch}.${ext}",
    "publisherName": "LogStudio",
    "verifyUpdateCodeSignature": false,
    "requestedExecutionLevel": "asInvoker",
    "signingHashAlgorithms": ["sha256"]
  },
  "portable": {
    "artifactName": "${productName}-${version}-${arch}-portable.${ext}",
    "requestExecutionLevel": "user"
  },
  "nsis": {
    "oneClick": false,
    "allowToChangeInstallationDirectory": true,
    "createDesktopShortcut": true,
    "createStartMenuShortcut": true,
    "shortcutName": "LogStudio",
    "installerIcon": "public/LogStudio_Logo.ico",
    "uninstallerIcon": "public/LogStudio_Logo.ico",
    "installerHeaderIcon": "public/LogStudio_Logo.ico",
    "deleteAppDataOnUninstall": false
  },
  "mac": {
    "target": "dmg",
    "icon": "LogStudio_Logo.png",
    "category": "public.app-category.utilities"
  },
  "linux": {
    "target": "AppImage",
    "icon": "LogStudio_Logo.png",
    "category": "Utility"
  }
}
